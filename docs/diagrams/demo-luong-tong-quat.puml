@startuml
title Luong demo tong quat he thong quan ly chuoi nha hang

skinparam defaultFontSize 12
skinparam activity {
  BackgroundColor #F8FBFF
  BorderColor #2C3E50
  ArrowColor #2C3E50
}
skinparam partition {
  BackgroundColor #FDFEFE
  BorderColor #7F8C8D
}
skinparam note {
  BackgroundColor #FFF8DC
  BorderColor #D35400
}

start

partition "Admin he thong" {
  :Dang nhap tai khoan admin;
  :Thiet lap du lieu nen\n- chi nhanh\n- ban, suc chua, ma QR\n- tai khoan nhan vien\n- tai khoan khach hang;
  :Kiem tra dashboard tong quan\nva trang thai van hanh;
}

partition "Quan ly chi nhanh" {
  :Dang nhap tai khoan manager;
  :Cap nhat thong tin chi nhanh,\ngio mo cua, dia chi, toa do;
  :Quan ly thuc don cua chi nhanh\nmon an, gia, trang thai ban;
}

partition "Khach hang" {
  :Truy cap website;
  :Xem trang chu, gioi thieu,\ntin tuc, khuyen mai, lien he;
  :Xem danh sach chi nhanh;
  if (Cho phep dinh vi?) then (Co)
    :Sap xep chi nhanh gan nhat;
  else (Khong)
    :Chon chi nhanh thu cong;
  endif
  :Xem menu theo chi nhanh;
  if (Da co tai khoan?) then (Chua)
    :Dang ky tai khoan\nkem CAPTCHA;
  endif
  :Dang nhap;
  :Chon chi nhanh, thoi gian den,\nso khach va ghi chu;
}

partition "He thong" {
  :Kiem tra du lieu dat ban\nCAPTCHA, gio mo cua,\nrate limit, gioi han lich tuong lai;
  :Tim ban phu hop theo suc chua\nva buffer giu cho 2 gio;
  if (Con ban hop le?) then (Co)
    :Tao order kieu reservation\nstatus=confirmed,\nexpected_end=arrival+2h;
  else (Het ban)
    :Thong bao het cho,\ngo y doi gio/chi nhanh;
    stop
  endif
}

partition "Khach hang" {
  :Dat mon truoc neu can;
  :Xem lich su dat ban,\nhoa don va trang thai phien ban;
}

partition "NV phuc vu" {
  :Mo man hinh quan ly ban;
  :Tiep nhan khach den dung lich;
}

partition "He thong" {
  if (Qua 15 phut chua check-in?) then (No-show)
    :Danh dau no-show,\ngiai phong ban;
    stop
  else (Khach den)
    :Cap nhat order sang pre-ordered/in_progress;
    :Cap nhat ban occupied;
  endif
}

partition "Khach hang / NV phuc vu" {
  :Goi them mon tai ban\nqua QR hoac nhan vien ghi order;
}

partition "He thong" {
  :Luu order_items,\ntinh gia mon va tong tien tam tinh;
  :Day danh sach mon cho bep\nqua API/realtime theo chi nhanh;
}

partition "NV bep" {
  :Xem mon cho xu ly;
  :Cap nhat trang thai mon\npending -> processing -> done;
}

partition "NV phuc vu" {
  :Nhan thong bao mon hoan thanh;
  :Phuc vu mon cho ban;
  :Danh dau mon da phuc vu;
  :Cap nhat trang thai ban khi can\navailable / occupied / cleaning;
}

partition "Khach hang" {
  :Theo doi bill tam tinh\ntu trang My Table / QR;
  :Gui yeu cau thanh toan;
}

partition "NV phuc vu / He thong thanh toan" {
  :Mo hoa don tam tinh;
  :Tao phien thanh toan;
  if (Phuong thuc thanh toan?) then (Tien mat)
    :Nhan tien va xac nhan thanh toan;
  else (Khong tien mat)
    if (VietQR / chuyen khoan?) then (Co)
      :Tao ma VietQR,\nnhan webhook SEPay neu co;
    else (MoMo)
      :Tao session MoMo,\nnhan webhook/return;
    endif
  endif
  :Cap nhat payment succeeded;
  :Cap nhat order completed,\nban sang cleaning;
  :Xuat hoa don PDF;
}

partition "Khach hang" {
  :Xem hoa don trong lich su;
  :Gui danh gia dich vu;
}

partition "Quan ly chi nhanh" {
  :Xem danh sach danh gia\nva thong ke diem danh gia;
  :Xem bao cao doanh thu,\nmon ban chay, khung gio, ban,\nkhach hang than thiet;
  :Xuat bao cao khi can;
}

partition "Admin he thong" {
  :Theo doi dashboard toan he thong;
  :Quan ly chi nhanh, nhan vien,\ntai khoan khach hang va khoa/mo khoa;
  :Xem log thao tac de kiem tra van hanh;
}

stop

legend right
  Demo bao quat cac nhom chuc nang:
  UC01-UC04: dang ky/dang nhap, chi nhanh, menu
  UC05-UC13: dat ban, tiep nhan, goi mon, bep, thanh toan, hoa don, danh gia
  UC14-UC17: bao cao, menu/chi nhanh, admin, tai khoan, nhan su, ban/QR
endlegend

@enduml
