@startuml
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam nodesep 30
skinparam ranksep 20

title Luong lop cot loi - Auth va Order

package "presentation" as PRES #E8F4FD {
  class AuthController <<controller>>
  class OrderController <<controller>>
  class WaiterController <<controller>>
}

package "application" as APP #FFF8E1 {
  class userService <<service>>
  class waiterService <<service>>
}

package "infrastructure" as INFRA #F3E5F5 {
  class SequelizeModels <<Repository>>
  class realtimeHub <<WebSocket>>
}

package "domain" as DOM #E8F5E9 {
  class CoreEntities <<entity>>
}

package "crosscutting" as CC #FFEBEE {
  class SharedUtils <<utils>>
}

PRES -[hidden]down- APP
APP -[hidden]down- INFRA
INFRA -[hidden]down- DOM

PRES --> APP
APP --> INFRA
INFRA ..> DOM
PRES ..> CC
APP ..> CC

AuthController --> userService
WaiterController --> waiterService
AuthController --> SequelizeModels
OrderController --> SequelizeModels
OrderController --> realtimeHub
waiterService --> SequelizeModels

note top of PRES
  **Auth:** register, login
  **Order (KH):** createOrder
  **Waiter (NV):** createOrder
end note

note bottom of INFRA
  SequelizeModels = User, Order,
  Table, OrderItem, Reservation
end note

@enduml
