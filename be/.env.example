# Database (bắt buộc)
DATABASE_URL=postgres://postgres:password@localhost:5432/restaurant

# Server
PORT=3000
NODE_ENV=development

# Bắt buộc — tối thiểu 16 ký tự (không dùng default_secret)
JWT_SECRET=your-long-random-secret-here-min-16-chars
JWT_EXPIRES_IN=2h

# Tùy chọn: Sequelize sync alter khi start (chỉ dev)
# DB_SYNC_ALTER=true

# CAPTCHA nội bộ: server sinh ảnh mã, user nhập lại mã
CAPTCHA_PROVIDER=code

# VietQR / SEPay
VIETQR_BANK_BIN=
VIETQR_ACCOUNT_NUMBER=
VIETQR_SERVICE_CODE=QRIBFTTA
SEPAY_ACCOUNT_NUMBER=
SEPAY_ORDER_PREFIX=DH
SEPAY_WEBHOOK_API_KEY=
