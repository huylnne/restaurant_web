# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurant
DB_USER=postgres
DB_PASSWORD=

# Server
PORT=3000

# Bắt buộc — tối thiểu 16 ký tự (không dùng default_secret)
JWT_SECRET=your-long-random-secret-here-min-16-chars
# Thời hạn access token (mặc định 2h). Chưa có refresh token / idle timeout phía client.
JWT_EXPIRES_IN=2h

# CAPTCHA đăng ký: math (mặc định) | recaptcha | turnstile
# CAPTCHA_PROVIDER=math
# reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
# Cloudflare Turnstile
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
